<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>
      Contact Me — Idris Umar Ahmad | Bibi Tech Compatibility
    </title>
    <meta
      name="description"
      content="Reach out, and I'll get back to you by email. Idris Umar Ahmad, Founder of Bibi Tech Compatibility, Kano, Nigeria."
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Inter:wght@400;500;600&family=IBM+Plex+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="./STYLE.CSS" />
    
  </head>
  <body>
    <header>
      <div class="navbar">
        <a href="index.html" class="brand">
          <img
            src="./IMAGES/logo.png"
            alt="Bibi Tech Compatibility logo"
            class="brand-logo"
          />
          <span>IDRIS UMAR AHMAD<small>BIBI TECH COMPATIBILITY</small></span>
        </a>
        <button
          class="nav-toggle"
          id="navToggle"
          aria-label="Toggle menu"
          aria-expanded="false"
        >
          ☰
        </button>
        <nav>
          <ul id="navList">
            <li><a href="index.html">Home</a></li>
            <li><a href="about.html">About</a></li>
            <li><a href="expertise.html">Expertise</a></li>
            <li><a href="projects.html">Projects</a></li>
            <li><a href="pricing.html">Pricing</a></li>
            <li><a href="why.html">Why Me</a></li>
            <li><a href="founder.html">Bibi Tech</a></li>
            <li>
              <a href="contact.html" class="nav-cta" aria-current="page"
                >Contact</a
              >
            </li>
          </ul>
        </nav>
      </div>
    </header>

    <main id="top">
      <section
        class="page-hero"
        style="padding: 64px 0 40px; border-bottom: 1px solid var(--line)"
      >
        <div class="wrap">
          <span class="eyebrow">Contact</span>
          <h1
            style="
              font-size: clamp(2rem, 5vw, 3.2rem);
              font-weight: 700;
              line-height: 1.05;
              letter-spacing: -0.01em;
              max-width: 20ch;
            "
          >
            Let's Build Something
          </h1>
          <p
            style="
              margin-top: 18px;
              font-size: 1.05rem;
              color: var(--text-muted);
              max-width: 56ch;
            "
          >
            Reach out, and I'll get back to you by email.
          </p>
        </div>
      </section>

      <section id="contact" style="border-bottom: none">
        <div class="wrap reveal">
          <div class="sec-head">
            <span class="sec-tag">Contact</span>
            <h2>Let's build something</h2>
          </div>
          <div class="contact-panel">
            <div>
              <ul class="contact-list">
                <li>
                  <span class="k">Email</span
                  ><span class="v"
                    ><a href="mailto:bibitechcompatibility@gmail.com"
                      >bibitechcompatibility@gmail.com</a
                    ></span
                  >
                </li>
                <li>
                  <span class="k">Phone</span
                  ><span class="v placeholder"
                    >+2349035855041, Or 09033451513</span
                  >
                </li>
                <li>
                  <span class="k">WhatsApp</span
                  ><span class="v placeholder">+2349035855041</span>
                </li>

                <li>
                  <span class="k">Location</span
                  ><span class="v">Kano State, Nigeria</span>
                </li>
              </ul>
            </div>
            <div class="contact-right">
              <h3>Send a message</h3>
              <p>
                Tell me a bit about your project and I'll reply directly to your
                email.
              </p>

              <form
                id="contactForm"
                class="contact-form"
                action="https://formsubmit.co/ajax/bibitechcompatibility@gmail.com"
                method="POST"
              >
                <input
                  type="hidden"
                  name="_subject"
                  value="New message from portfolio site"
                />
                <input type="hidden" name="_captcha" value="false" />
                <input type="text" name="_honey" style="display: none" />

                <label class="field">
                  <span class="k">Name</span>
                  <input
                    type="text"
                    name="name"
                    placeholder="Your full name"
                    required
                  />
                </label>

                <label class="field">
                  <span class="k">Email</span>
                  <input
                    type="email"
                    name="email"
                    placeholder="you@example.com"
                    required
                  />
                </label>

                <label class="field">
                  <span class="k">Subject</span>
                  <input
                    type="text"
                    name="subject"
                    placeholder="What is this about?"
                  />
                </label>

                <label class="field">
                  <span class="k">Message</span>
                  <textarea
                    name="message"
                    rows="5"
                    placeholder="Tell me about your project..."
                    required
                  ></textarea>
                </label>

                <button
                  type="submit"
                  class="btn btn-primary"
                  id="contactSubmit"
                >
                  Send message →
                </button>
                <p
                  class="form-status"
                  id="formStatus"
                  role="status"
                  aria-live="polite"
                ></p>
              </form>
            </div>
          </div>
        </div>
      </section>
    </main>

    <footer>
      <img
        src="./IMAGES/logo.png"
        alt="Bibi Tech Compatibility logo"
        style="height: 36px; width: auto; margin: 0 auto 14px; opacity: 0.85"
      />
      <p>
        © <span id="year"></span> Idris Umar Ahmad · Bibi Tech Compatibility ·
        Kano State, Nigeria
      </p>
    </footer>

    <script src="https://js.paystack.co/v1/inline.js"></script>
    <script src="./script.js"></script>
  </body>
</html>
