<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Let's Build Something — Idris Umar Ahmad | Bibi Tech Compatibility</title>
<meta name="description" content="Reach out, and I'll get back to you by email. Idris Umar Ahmad, Founder of Bibi Tech Compatibility, Kano, Nigeria.">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Inter:wght@400;500;600&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet">
<link rel="icon" type="image/png" href="data:image/png;base64,">
<style>
:root{
    --bg:#F5F7F9;
    --surface:#FFFFFF;
    --surface-2:#EDF1F5;
    --line:#D9E1E8;
    --text:#121A22;
    --text-muted:#5C6B79;
    --amber:#C2760F;
    --amber-dim:#E4B486;
    --teal:#137A67;
    --teal-dim:#A9D9CE;
    --radius:2px;
    --maxw:1180px;
  }

  *{margin:0;padding:0;box-sizing:border-box;}
  html{scroll-behavior:smooth;}

  @media (prefers-reduced-motion: reduce){
    html{scroll-behavior:auto;}
    *{animation-duration:0.01ms !important; transition-duration:0.01ms !important;}
  }

  body{
    background:var(--bg);
    color:var(--text);
    font-family:'Inter', sans-serif;
    line-height:1.6;
  }

  .mono{font-family:'IBM Plex Mono', monospace;}
  h1,h2,h3,.display{font-family:'Space Grotesk', sans-serif;}

  a{color:inherit;text-decoration:none;}
  img{max-width:100%;display:block;}

  .wrap{max-width:var(--maxw); margin:0 auto; padding:0 28px; position:relative; z-index:1;}

  ::selection{background:var(--amber); color:#FFFFFF;}

  a:focus-visible, button:focus-visible, .node:focus-visible{
    outline:2px solid var(--teal);
    outline-offset:3px;
  }

  /* ---------- NAV ---------- */
  header{
    position:sticky; top:0; z-index:50;
    background:rgba(245,247,249,0.88);
    backdrop-filter:blur(8px);
    border-bottom:1px solid var(--line);
  }
  .navbar{
    display:flex; align-items:center; justify-content:space-between;
    padding:16px 28px; max-width:var(--maxw); margin:0 auto;
  }
  .brand{
    font-family:'Space Grotesk', sans-serif;
    font-weight:700; font-size:1.05rem; letter-spacing:0.02em;
    display:flex; align-items:center; gap:10px;
  }
  .brand-logo{height:42px; width:auto; display:block;}
  .brand small{display:block; font-family:'IBM Plex Mono', monospace; font-weight:400; font-size:0.62rem; color:var(--text-muted); letter-spacing:0.12em;}
  nav ul{list-style:none; display:flex; gap:28px;}
  nav a{
    font-family:'IBM Plex Mono', monospace; font-size:0.72rem; letter-spacing:0.08em;
    color:var(--text-muted); text-transform:uppercase; transition:color .2s;
    position:relative; padding-bottom:4px;
  }
  nav a::after{content:"";position:absolute;left:0;bottom:0;width:0;height:1px;background:var(--amber);transition:width .25s;}
  nav a:hover{color:var(--text);}
  nav a:hover::after{width:100%;}
  nav a[aria-current="page"]{color:var(--text);}
  nav a[aria-current="page"]::after{width:100%;background:var(--teal);}
  .nav-toggle{display:none; background:none; border:1px solid var(--line); color:var(--text); width:38px; height:38px; border-radius:var(--radius); cursor:pointer;}

  .nav-cta{
    border:1px solid var(--amber); color:var(--amber) !important; padding:8px 16px; border-radius:var(--radius);
  }
  .nav-cta::after{display:none;}
  .nav-cta:hover{background:var(--amber); color:#fff !important;}

  /* ---------- HERO ---------- */
  .hero{
    padding:96px 0 60px;
    position:relative;
  }
  .eyebrow{
    font-family:'IBM Plex Mono', monospace; font-size:0.72rem; letter-spacing:0.18em;
    color:var(--teal); text-transform:uppercase; display:flex; align-items:center; gap:10px; margin-bottom:22px;
  }
  .eyebrow::before{content:"";width:22px;height:1px;background:var(--teal);}

  .hero h1{
    font-size:clamp(2.4rem, 6vw, 4.4rem);
    font-weight:700; line-height:1.04; letter-spacing:-0.01em;
    max-width:14ch;
  }
  .hero h1 span{color:var(--amber);}

  .hero-role{
    margin-top:20px; font-family:'IBM Plex Mono', monospace; font-size:0.85rem; color:var(--text-muted);
    letter-spacing:0.02em; max-width:52ch;
  }
  .hero-role b{color:var(--text); font-weight:500;}

  .hero-lead{
    margin-top:22px; font-size:1.08rem; color:var(--text-muted); max-width:56ch;
  }

  .hero-cta{display:flex; gap:16px; margin-top:36px; flex-wrap:wrap;}
  .btn{
    font-family:'IBM Plex Mono', monospace; font-size:0.78rem; letter-spacing:0.06em;
    padding:14px 24px; border-radius:var(--radius); text-transform:uppercase;
    display:inline-flex; align-items:center; gap:10px; transition:all .2s; cursor:pointer; border:none;
  }
  .btn-primary{background:var(--amber); color:#FFFFFF; font-weight:500;}
  .btn-primary:hover{background:#A0630C; transform:translateY(-1px);}
  .btn-ghost{border:1px solid var(--line); color:var(--text);}
  .btn-ghost:hover{border-color:var(--teal); color:var(--teal);}

  .hero-grid{
    display:grid; grid-template-columns:1fr 0.9fr; gap:48px; align-items:center;
  }
  .hero-photo{
    display:flex; justify-content:center;
  }
  .photo-frame{
    position:relative; width:100%; max-width:460px; aspect-ratio:4/5;
    border-radius:14px; overflow:hidden;
    border-top:3px solid var(--amber);
    border-left:1px solid var(--line); border-right:1px solid var(--line); border-bottom:1px solid var(--line);
    background:var(--surface-2);
    box-shadow:0 30px 55px rgba(18,26,34,0.18);
  }
  .photo-frame img{
    width:100%; height:100%; object-fit:cover; object-position:top center; display:block;
  }
  .photo-overlay{
    position:absolute; inset:auto 0 0 0; padding:28px 26px 24px;
    background:linear-gradient(to top, rgba(6,10,14,0.92) 0%, rgba(6,10,14,0.55) 55%, rgba(6,10,14,0) 100%);
    display:flex; flex-direction:column; gap:3px;
  }
  .photo-name{font-family:'Space Grotesk', sans-serif; font-weight:700; font-size:1.15rem; color:#fff;}
  .photo-role{font-family:'IBM Plex Mono', monospace; font-size:0.72rem; color:rgba(255,255,255,0.82); text-transform:uppercase; letter-spacing:0.08em;}

  /* schematic diagram */
  .schematic{
    margin-top:64px;
    display:flex; justify-content:center;
  }
  .schematic svg{width:100%; max-width:640px; height:auto;}
  .node-label{font-family:'IBM Plex Mono', monospace; font-size:13px; fill:var(--text-muted); transition:fill .2s;}
  .node-circle{fill:var(--surface); stroke:var(--line); stroke-width:1.5; transition:stroke .25s, fill .25s;}
  .trace{stroke:var(--line); stroke-width:1.5; fill:none; transition:stroke .25s;}
  .hub-circle{fill:var(--surface-2); stroke:var(--amber); stroke-width:1.5;}
  .hub-text{font-family:'Space Grotesk', sans-serif; font-weight:700; fill:var(--text); font-size:15px;}
  .hub-sub{font-family:'IBM Plex Mono', monospace; fill:var(--text-muted); font-size:9px; letter-spacing:0.08em;}
  .node{cursor:pointer;}
  .node:hover .node-circle, .node:focus .node-circle{stroke:var(--teal); fill:var(--surface-2);}
  .node:hover .node-label, .node:focus .node-label{fill:var(--teal);}
  .node:hover ~ .trace{stroke:var(--teal);}
  .pulse{fill:var(--teal); opacity:0;}

  .schematic-mobile{display:none; margin-top:48px;}
  .schematic-mobile ul{list-style:none; display:grid; gap:10px;}
  .schematic-mobile li{
    font-family:'IBM Plex Mono', monospace; font-size:0.78rem; color:var(--text-muted);
    border:1px solid var(--line); border-radius:var(--radius); padding:12px 16px;
    display:flex; align-items:center; gap:10px;
  }
  .schematic-mobile li::before{content:"◆"; color:var(--amber); font-size:0.6rem;}

  /* ---------- SECTION GENERIC ---------- */
  section{padding:100px 0; position:relative; border-bottom:1px solid var(--line);}
  section:nth-of-type(odd){background:var(--bg);}
  section:nth-of-type(even){background:var(--surface);}
  section:nth-of-type(even) .stat-panel,
  section:nth-of-type(even) .proj-card,
  section:nth-of-type(even) .info-card{
    background:var(--bg);
  }
  .sec-head{margin-bottom:52px; max-width:64ch;}
  .sec-tag{
    font-family:'IBM Plex Mono', monospace; font-size:0.72rem; letter-spacing:0.18em;
    color:var(--amber); text-transform:uppercase; display:block; margin-bottom:14px;
  }
  .sec-tag::before{content:"// ";}
  .sec-head h2{font-size:clamp(1.7rem, 3.4vw, 2.4rem); font-weight:600; letter-spacing:-0.01em;}
  .sec-head p{color:var(--text-muted); margin-top:14px; font-size:1rem;}

  .reveal{opacity:0; transform:translateY(18px); transition:opacity .6s ease, transform .6s ease;}
  .reveal.in{opacity:1; transform:translateY(0);}

  /* ---------- ABOUT ---------- */
  .about-grid{display:grid; grid-template-columns:1.3fr 1fr; gap:60px; align-items:start;}
  .about-grid p{color:var(--text-muted); margin-bottom:16px; font-size:1.02rem;}
  .about-grid p b{color:var(--text); font-weight:500;}
  .stat-panel{
    background:var(--surface); border:1px solid var(--line); border-radius:var(--radius); padding:28px;
  }
  .stat-panel .mission-label{font-family:'IBM Plex Mono', monospace; font-size:0.68rem; color:var(--teal); letter-spacing:0.14em; text-transform:uppercase; margin-bottom:12px; display:block;}
  .stat-panel blockquote{font-family:'Space Grotesk', sans-serif; font-size:1.15rem; line-height:1.45; font-weight:500; color:var(--text);}
  .stat-panel .loc{margin-top:22px; padding-top:20px; border-top:1px solid var(--line); font-family:'IBM Plex Mono', monospace; font-size:0.78rem; color:var(--text-muted); display:flex; justify-content:space-between;}

  /* ---------- EXPERTISE (tabs) ---------- */
  .tabs-wrap{display:grid; grid-template-columns:260px 1fr; gap:0; border:1px solid var(--line); border-radius:var(--radius); overflow:hidden;}
  .tab-list{display:flex; flex-direction:column; background:var(--surface); border-right:1px solid var(--line);}
  .tab-btn{
    text-align:left; background:none; border:none; color:var(--text-muted);
    font-family:'IBM Plex Mono', monospace; font-size:0.78rem; letter-spacing:0.03em;
    padding:18px 22px; border-bottom:1px solid var(--line); cursor:pointer;
    display:flex; align-items:center; justify-content:space-between; transition:all .2s;
  }
  .tab-btn .num{color:var(--amber-dim); font-size:0.7rem;}
  .tab-btn:last-child{border-bottom:none;}
  .tab-btn:hover{color:var(--text); background:var(--surface-2);}
  .tab-btn.active{color:var(--text); background:var(--surface-2); border-left:2px solid var(--amber); padding-left:20px;}
  .tab-btn.active .num{color:var(--amber);}

  .tab-panels{padding:40px; background:var(--bg);}
  .tab-panel{display:none;}
  .tab-panel.active{display:block; animation:fadeIn .3s ease;}
  @keyframes fadeIn{from{opacity:0; transform:translateY(6px);} to{opacity:1; transform:translateY(0);}}
  .tab-panel h3{font-size:1.3rem; margin-bottom:6px;}
  .tab-panel .tab-desc{color:var(--text-muted); font-size:0.92rem; margin-bottom:22px;}
  .chip-row{display:flex; flex-wrap:wrap; gap:10px;}
  .chip{
    font-family:'IBM Plex Mono', monospace; font-size:0.74rem; color:var(--text);
    border:1px solid var(--line); padding:8px 14px; border-radius:var(--radius); background:var(--surface);
  }

  /* ---------- PROJECTS ---------- */
  .proj-grid{display:grid; grid-template-columns:repeat(auto-fill, minmax(280px, 1fr)); gap:20px;}
  .proj-card{
    background:var(--surface); border:1px solid var(--line); border-radius:var(--radius);
    padding:26px; transition:border-color .25s, transform .25s;
  }
  .proj-card:hover{border-color:var(--amber-dim); transform:translateY(-3px);}
  .proj-index{font-family:'IBM Plex Mono', monospace; font-size:0.72rem; color:var(--amber); margin-bottom:14px; display:block;}
  .proj-card h3{font-size:1.06rem; font-weight:600; margin-bottom:8px;}
  .proj-card p{font-size:0.88rem; color:var(--text-muted);}

  /* ---------- PRICING ---------- */
  .pricing-grid{display:grid; grid-template-columns:1.3fr 1fr; gap:32px; align-items:start;}
  .service-panel{border:1px solid var(--line); border-radius:var(--radius); background:var(--surface); overflow:hidden;}
  .service-list{list-style:none;}
  .service-list li{
    display:flex; align-items:center; justify-content:space-between; gap:16px;
    padding:16px 22px; border-bottom:1px solid var(--line);
  }
  .service-list li:last-child{border-bottom:none;}
  .service-list label{display:flex; align-items:center; gap:14px; cursor:pointer; flex:1;}
  .service-check{width:18px; height:18px; accent-color:var(--amber); cursor:pointer; flex-shrink:0;}
  .service-name{font-size:0.96rem; color:var(--text);}
  .service-price{font-family:'IBM Plex Mono', monospace; font-size:0.84rem; color:var(--text-muted); white-space:nowrap;}

  .quote-summary{
    position:sticky; top:90px;
    border:1px solid var(--line); border-radius:var(--radius); background:var(--surface);
    padding:28px; display:flex; flex-direction:column; gap:18px;
  }
  .quote-summary h3{font-size:1.1rem;}
  .summary-list{list-style:none; display:grid; gap:10px; min-height:24px;}
  .summary-list li{
    display:flex; justify-content:space-between; gap:12px;
    font-family:'IBM Plex Mono', monospace; font-size:0.78rem; color:var(--text-muted);
  }
  .summary-empty{font-style:italic;}
  .summary-total{
    display:flex; justify-content:space-between; align-items:baseline;
    padding-top:16px; border-top:1px solid var(--line);
    font-family:'Space Grotesk', sans-serif; font-weight:700; font-size:1.2rem; color:var(--text);
  }
  .quote-summary .field input{width:100%;}
  .quote-summary .btn{width:100%; justify-content:center;}
  .pay-note{font-family:'IBM Plex Mono', monospace; font-size:0.68rem; color:var(--text-muted); line-height:1.5;}

  /* ---------- WHY / DIAGNOSTICS ---------- */
  .diag-panel{border:1px solid var(--line); border-radius:var(--radius); background:var(--surface); overflow:hidden;}
  .diag-row{
    display:flex; align-items:center; justify-content:space-between; gap:20px;
    padding:18px 26px; border-bottom:1px solid var(--line);
  }
  .diag-row:last-child{border-bottom:none;}
  .diag-left{display:flex; align-items:center; gap:16px;}
  .diag-status{
    font-family:'IBM Plex Mono', monospace; font-size:0.68rem; color:var(--teal);
    border:1px solid var(--teal-dim); padding:4px 10px; border-radius:12px; letter-spacing:0.06em;
  }
  .diag-row span.label{font-size:0.98rem; color:var(--text);}

  /* ---------- EDUCATION / FOUNDER ---------- */
  .split-grid{display:grid; grid-template-columns:1fr 1fr; gap:24px;}
  .info-card{
    border:1px solid var(--line); border-radius:var(--radius); padding:30px; background:var(--surface);
  }
  .info-card .sec-tag{margin-bottom:16px;}
  .info-card h3{font-size:1.15rem; margin-bottom:10px;}
  .info-card p{color:var(--text-muted); font-size:0.94rem;}

  /* ---------- CONTACT ---------- */
  .contact-panel{
    border:1px solid var(--line); border-radius:var(--radius); background:var(--surface);
    padding:48px; display:grid; grid-template-columns:1fr 1fr; gap:40px;
  }
  .contact-list{list-style:none; display:grid; gap:18px;}
  .contact-list li{display:flex; flex-direction:column; gap:4px; border-bottom:1px dashed var(--line); padding-bottom:14px;}
  .contact-list .k{font-family:'IBM Plex Mono', monospace; font-size:0.66rem; color:var(--teal); letter-spacing:0.14em; text-transform:uppercase;}
  .contact-list .v{font-size:0.98rem; color:var(--text);}
  .contact-list .v.placeholder{color:var(--text-muted); font-style:italic;}
  .contact-list .v a{color:var(--amber); border-bottom:1px solid transparent; transition:border-color .2s;}
  .contact-list .v a:hover{border-color:var(--amber);}
  .contact-right h3{font-size:1.4rem; margin-bottom:14px;}
  .contact-right p{color:var(--text-muted); margin-bottom:24px;}

  .contact-form{display:grid; gap:18px;}
  .field{display:grid; gap:8px;}
  .field .k{font-family:'IBM Plex Mono', monospace; font-size:0.66rem; color:var(--teal); letter-spacing:0.14em; text-transform:uppercase;}
  .field input, .field textarea{
    font-family:'Inter', sans-serif; font-size:0.95rem; color:var(--text);
    background:var(--bg); border:1px solid var(--line); border-radius:var(--radius);
    padding:12px 14px; resize:vertical; transition:border-color .2s;
  }
  .field input:focus, .field textarea:focus{outline:none; border-color:var(--amber);}
  .field input::placeholder, .field textarea::placeholder{color:var(--text-muted);}
  .contact-form .btn{width:fit-content; border:none;}
  .contact-form .btn:disabled{opacity:0.6; cursor:not-allowed;}
  .form-status{font-family:'IBM Plex Mono', monospace; font-size:0.78rem; min-height:1.2em;}
  .form-status.success{color:var(--teal);}
  .form-status.error{color:#B3261E;}

  footer{padding:36px 0; text-align:center;}
  footer p{font-family:'IBM Plex Mono', monospace; font-size:0.72rem; color:var(--text-muted); letter-spacing:0.04em;}

  /* ---------- SKILLS MARQUEE ---------- */
  .marquee-strip{
    background:var(--text); overflow:hidden; padding:20px 0; border-bottom:1px solid var(--line);
  }
  .marquee-track{
    display:flex; align-items:center; gap:28px; width:max-content;
    animation:marquee 32s linear infinite;
    white-space:nowrap;
  }
  .marquee-track span{
    font-family:'Space Grotesk', sans-serif; font-weight:600; font-size:1.3rem;
    color:var(--bg); text-transform:uppercase; letter-spacing:0.01em;
  }
  .marquee-track span.sep{color:var(--amber); font-size:1rem;}
  @keyframes marquee{
    from{transform:translateX(0);}
    to{transform:translateX(-50%);}
  }
  .marquee-strip:hover .marquee-track{animation-play-state:paused;}

  /* ---------- RESPONSIVE ---------- */
  @media (max-width: 900px){
    .about-grid, .split-grid, .contact-panel, .pricing-grid{grid-template-columns:1fr;}
    .tabs-wrap{grid-template-columns:1fr;}
    .tab-list{flex-direction:row; overflow-x:auto; border-right:none; border-bottom:1px solid var(--line);}
    .tab-btn{border-bottom:none; border-right:1px solid var(--line); white-space:nowrap;}
    .tab-btn.active{border-left:none; border-bottom:2px solid var(--amber); padding-left:22px;}
    .schematic{display:none;}
    .schematic-mobile{display:block;}
    .hero-grid{grid-template-columns:1fr; gap:36px;}
    .hero-photo{order:-1;}
    .photo-frame{max-width:300px;}
    .quote-summary{position:static;}
  }
  @media (max-width: 720px){
    nav ul{
      position:fixed; top:64px; left:0; right:0; background:var(--bg); border-bottom:1px solid var(--line);
      flex-direction:column; padding:20px 28px; gap:18px; transform:translateY(-120%); transition:transform .3s; z-index:40;
    }
    nav ul.open{transform:translateY(0);}
    .nav-toggle{display:block;}
    .contact-panel{padding:28px;}
  }
</style>
</head>
<body>
<header>
  <div class="navbar">
    <a href="index.html" class="brand">
      <img src="data:image/webp;base64," alt="Bibi Tech Compatibility logo" class="brand-logo">
      <span>IDRIS UMAR AHMAD<small>BIBI TECH COMPATIBILITY</small></span>
    </a>
    <button class="nav-toggle" id="navToggle" aria-label="Toggle menu" aria-expanded="false">☰</button>
    <nav>
      <ul id="navList">
        <li><a href="index.html">Home</a></li>
        <li><a href="about.html">About</a></li>
        <li><a href="expertise.html">Expertise</a></li>
        <li><a href="projects.html">Projects</a></li>
        <li><a href="pricing.html">Pricing</a></li>
        <li><a href="why.html">Why Me</a></li>
        <li><a href="founder.html">Bibi Tech</a></li>
        <li><a href="contact.html" class="nav-cta" aria-current="page">Contact</a></li>
      </ul>
    </nav>
  </div>
</header>

<main id="top">
  <section class="page-hero" style="padding:64px 0 40px;border-bottom:1px solid var(--line);">
    <div class="wrap">
      <span class="eyebrow">Contact</span>
      <h1 style="font-size:clamp(2rem, 5vw, 3.2rem); font-weight:700; line-height:1.05; letter-spacing:-0.01em; max-width:20ch;">Let's Build Something</h1>
      <p style="margin-top:18px; font-size:1.05rem; color:var(--text-muted); max-width:56ch;">Reach out, and I'll get back to you by email.</p>
    </div>
  </section>

<section id="contact" style="border-bottom:none;">
    <div class="wrap reveal">
      <div class="sec-head">
        <span class="sec-tag">Contact</span>
        <h2>Let's build something</h2>
      </div>
      <div class="contact-panel">
        <div>
          <ul class="contact-list">
            <li><span class="k">Email</span><span class="v"><a href="mailto:bibitechcompatibility@gmail.com">bibitechcompatibility@gmail.com</a></span></li>
            <li><span class="k">Phone</span><span class="v placeholder">Add your preferred phone number</span></li>
            <li><span class="k">WhatsApp</span><span class="v placeholder">Add your WhatsApp link</span></li>
            <li><span class="k">GitHub</span><span class="v placeholder">Add your GitHub profile</span></li>
            <li><span class="k">LinkedIn</span><span class="v placeholder">Add your LinkedIn profile</span></li>
            <li><span class="k">Location</span><span class="v">Kano State, Nigeria</span></li>
          </ul>
        </div>
        <div class="contact-right">
          <h3>Send a message</h3>
          <p>Tell me a bit about your project and I'll reply directly to your email.</p>

          <form id="contactForm" class="contact-form" action="https://formsubmit.co/ajax/bibitechcompatibility@gmail.com" method="POST">
            <input type="hidden" name="_subject" value="New message from portfolio site">
            <input type="hidden" name="_captcha" value="false">
            <input type="text" name="_honey" style="display:none">

            <label class="field">
              <span class="k">Name</span>
              <input type="text" name="name" placeholder="Your full name" required>
            </label>

            <label class="field">
              <span class="k">Email</span>
              <input type="email" name="email" placeholder="you@example.com" required>
            </label>

            <label class="field">
              <span class="k">Subject</span>
              <input type="text" name="subject" placeholder="What is this about?">
            </label>

            <label class="field">
              <span class="k">Message</span>
              <textarea name="message" rows="5" placeholder="Tell me about your project..." required></textarea>
            </label>

            <button type="submit" class="btn btn-primary" id="contactSubmit">Send message →</button>
            <p class="form-status" id="formStatus" role="status" aria-live="polite"></p>
          </form>
        </div>
      </div>
    </div>
  </section>
</main>

<footer>
  <img src="data:image/webp;base64," alt="Bibi Tech Compatibility logo" style="height:36px;width:auto;margin:0 auto 14px;opacity:0.85;">
  <p>© <span id="year"></span> Idris Umar Ahmad · Bibi Tech Compatibility · Kano State, Nigeria</p>
</footer>



<script src="https://js.paystack.co/v1/inline.js"></script>
<script>
// mobile nav toggle
  const navToggle = document.getElementById('navToggle');
  const navList = document.getElementById('navList');
  navToggle.addEventListener('click', () => {
    const open = navList.classList.toggle('open');
    navToggle.setAttribute('aria-expanded', open);
  });
  navList.querySelectorAll('a').forEach(a => a.addEventListener('click', () => {
    navList.classList.remove('open');
    navToggle.setAttribute('aria-expanded', false);
  }));

  // tabs
  const tabBtns = document.querySelectorAll('.tab-btn');
  const tabPanels = document.querySelectorAll('.tab-panel');
  tabBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      tabBtns.forEach(b => { b.classList.remove('active'); b.setAttribute('aria-selected','false'); });
      tabPanels.forEach(p => p.classList.remove('active'));
      btn.classList.add('active');
      btn.setAttribute('aria-selected','true');
      document.querySelector(`.tab-panel[data-panel="${btn.dataset.tab}"]`).classList.add('active');
    });
  });

  // scroll reveal
  const revealEls = document.querySelectorAll('.reveal');
  const io = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('in');
        io.unobserve(entry.target);
      }
    });
  }, { threshold: 0.12 });
  revealEls.forEach(el => io.observe(el));

  // footer year
  document.getElementById('year').textContent = new Date().getFullYear();

  // contact form submission (via FormSubmit AJAX endpoint)
  const contactForm = document.getElementById('contactForm');
  const formStatus = document.getElementById('formStatus');
  const contactSubmit = document.getElementById('contactSubmit');

  if (contactForm) {
    contactForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      formStatus.textContent = '';
      formStatus.classList.remove('success', 'error');
      contactSubmit.disabled = true;
      contactSubmit.textContent = 'Sending...';

      try {
        const response = await fetch(contactForm.action, {
          method: 'POST',
          headers: { 'Accept': 'application/json' },
          body: new FormData(contactForm)
        });

        if (response.ok) {
          formStatus.textContent = 'Message sent — thank you. I will reply by email soon.';
          formStatus.classList.add('success');
          contactForm.reset();
        } else {
          throw new Error('Request failed');
        }
      } catch (err) {
        formStatus.textContent = 'Something went wrong. Please email bibitechcompatibility@gmail.com directly.';
        formStatus.classList.add('error');
      } finally {
        contactSubmit.disabled = false;
        contactSubmit.textContent = 'Send message →';
      }
    });
  }

  // pricing calculator + Paystack checkout
  const PAYSTACK_PUBLIC_KEY = 'pk_test_REPLACE_WITH_YOUR_PAYSTACK_PUBLIC_KEY';

  const serviceChecks = document.querySelectorAll('.service-check');
  const summaryList = document.getElementById('summaryList');
  const totalAmountEl = document.getElementById('totalAmount');
  const payButton = document.getElementById('payButton');
  const payerNameInput = document.getElementById('payerName');
  const payerEmailInput = document.getElementById('payerEmail');
  const paymentStatus = document.getElementById('paymentStatus');

  function formatNaira(amount) {
    return '₦' + amount.toLocaleString('en-NG');
  }

  function updateQuote() {
    const selected = Array.from(serviceChecks).filter(c => c.checked);
    const total = selected.reduce((sum, c) => sum + Number(c.dataset.price), 0);

    if (selected.length === 0) {
      summaryList.innerHTML = '<li class="summary-empty">No services selected yet.</li>';
      payButton.disabled = true;
      payButton.textContent = 'Select a service to continue';
    } else {
      summaryList.innerHTML = selected.map(c =>
        `<li><span>${c.dataset.name}</span><span>${formatNaira(Number(c.dataset.price))}</span></li>`
      ).join('');
      payButton.disabled = false;
      payButton.textContent = `Pay ${formatNaira(total)} →`;
    }

    totalAmountEl.textContent = formatNaira(total);
    return { selected, total };
  }

  if (summaryList) {
    serviceChecks.forEach(c => c.addEventListener('change', updateQuote));
    updateQuote();
  }

  if (payButton) {
    payButton.addEventListener('click', () => {
      const { selected, total } = updateQuote();
      paymentStatus.textContent = '';
      paymentStatus.classList.remove('success', 'error');

      if (selected.length === 0) return;

      const name = payerNameInput.value.trim();
      const email = payerEmailInput.value.trim();

      if (!name) {
        paymentStatus.textContent = 'Please enter your full name.';
        paymentStatus.classList.add('error');
        payerNameInput.focus();
        return;
      }
      if (!email || !email.includes('@')) {
        paymentStatus.textContent = 'Please enter a valid email address.';
        paymentStatus.classList.add('error');
        payerEmailInput.focus();
        return;
      }
      if (typeof PaystackPop === 'undefined') {
        paymentStatus.textContent = 'Payment system failed to load. Please check your connection and try again.';
        paymentStatus.classList.add('error');
        return;
      }

      const serviceNames = selected.map(c => c.dataset.name).join(', ');
      const reference = 'BTC-' + Date.now() + '-' + Math.floor(Math.random() * 100000);

      const handler = PaystackPop.setup({
        key: PAYSTACK_PUBLIC_KEY,
        email: email,
        amount: total * 100, // kobo
        currency: 'NGN',
        ref: reference,
        metadata: {
          custom_fields: [
            { display_name: 'Full Name', variable_name: 'full_name', value: name },
            { display_name: 'Services', variable_name: 'services', value: serviceNames }
          ]
        },
        callback: function(response) {
          paymentStatus.textContent = 'Payment successful — reference ' + response.reference + '. Thank you! I will reach out by email to get started.';
          paymentStatus.classList.add('success');
        },
        onClose: function() {
          paymentStatus.textContent = 'Payment window closed. No charge was made.';
        }
      });

      handler.openIframe();
    });
  }
</script>


</body>
</html>
