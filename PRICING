<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Pricing & Quotes — Idris Umar Ahmad | Bibi Tech Compatibility</title>
    <meta
      name="description"
      content="Build a quote from the services you need and pay securely online. Idris Umar Ahmad, Founder of Bibi Tech Compatibility, Kano, Nigeria."
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Inter:wght@400;500;600&family=IBM+Plex+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <link rel="icon" type="image/png" href="./IMAGES/logo.png" />
    <link rel="stylesheet" href="./STYLE.CSS" />
  
  </head>
  <body>
    <header>
      <div class="navbar">
        <a href="index.html" class="brand">
          <img
            src="./IMAGES/logo.png"
            alt="Bibi Tech Compatibility logo"
            class="brand-logo"
          />
          <span>IDRIS UMAR AHMAD<small>BIBI TECH COMPATIBILITY</small></span>
        </a>
        <button
          class="nav-toggle"
          id="navToggle"
          aria-label="Toggle menu"
          aria-expanded="false"
        >
          ☰
        </button>
        <nav>
          <ul id="navList">
            <li><a href="index.html">Home</a></li>
            <li><a href="about.html">About</a></li>
            <li><a href="expertise.html">Expertise</a></li>
            <li><a href="projects.html">Projects</a></li>
            <li><a href="pricing.html" aria-current="page">Pricing</a></li>
            <li><a href="why.html">Why Me</a></li>
            <li><a href="founder.html">Bibi Tech</a></li>
            <li><a href="contact.html" class="nav-cta">Contact</a></li>
          </ul>
        </nav>
      </div>
    </header>

    <main id="top">
      <section
        class="page-hero"
        style="padding: 64px 0 40px; border-bottom: 1px solid var(--line)"
      >
        <div class="wrap">
          <span class="eyebrow">Pricing</span>
          <h1
            style="
              font-size: clamp(2rem, 5vw, 3.2rem);
              font-weight: 700;
              line-height: 1.05;
              letter-spacing: -0.01em;
              max-width: 20ch;
            "
          >
            Pricing & Quotes
          </h1>
          <p
            style="
              margin-top: 18px;
              font-size: 1.05rem;
              color: var(--text-muted);
              max-width: 56ch;
            "
          >
            Build a quote from the services you need and pay securely online.
          </p>
        </div>
      </section>

      <section id="pricing">
        <div class="wrap reveal">
          <div class="sec-head">
            <span class="sec-tag">Pricing</span>
            <h2>Build your own quote</h2>
            <p>
              Select the services you need. The total updates automatically, and
              you can pay securely online to get started.
            </p>
          </div>

          <div class="pricing-grid">
            <div class="service-panel">
              <ul class="service-list">
                <li>
                  <label>
                    <input
                      type="checkbox"
                      class="service-check"
                      data-price="80000"
                      data-name="Portfolio Website"
                    />
                    <span class="service-name">Portfolio Website</span>
                  </label>
                  <span class="service-price">₦80,000</span>
                </li>
                <li>
                  <label>
                    <input
                      type="checkbox"
                      class="service-check"
                      data-price="180000"
                      data-name="Business Website"
                    />
                    <span class="service-name">Business Website</span>
                  </label>
                  <span class="service-price">₦180,000</span>
                </li>
                <li>
                  <label>
                    <input
                      type="checkbox"
                      class="service-check"
                      data-price="220000"
                      data-name="Desktop / Database Application"
                    />
                    <span class="service-name"
                      >Desktop / Database Application</span
                    >
                  </label>
                  <span class="service-price">₦220,000</span>
                </li>
                <li>
                  <label>
                    <input
                      type="checkbox"
                      class="service-check"
                      data-price="25000"
                      data-name="Logo Design"
                    />
                    <span class="service-name">Logo Design</span>
                  </label>
                  <span class="service-price">₦25,000</span>
                </li>
                <li>
                  <label>
                    <input
                      type="checkbox"
                      class="service-check"
                      data-price="40000"
                      data-name="Full Brand Identity"
                    />
                    <span class="service-name">Full Brand Identity</span>
                  </label>
                  <span class="service-price">₦40,000</span>
                </li>
                <li>
                  <label>
                    <input
                      type="checkbox"
                      class="service-check"
                      data-price="12000"
                      data-name="Flyer / Poster Design"
                    />
                    <span class="service-name">Flyer / Poster Design</span>
                  </label>
                  <span class="service-price">₦12,000</span>
                </li>
                <li>
                  <label>
                    <input
                      type="checkbox"
                      class="service-check"
                      data-price="8000"
                      data-name="Business Card Design"
                    />
                    <span class="service-name">Business Card Design</span>
                  </label>
                  <span class="service-price">₦8,000</span>
                </li>
                <li>
                  <label>
                    <input
                      type="checkbox"
                      class="service-check"
                      data-price="10000"
                      data-name="Computer Repair / Troubleshooting"
                    />
                    <span class="service-name"
                      >Computer Repair / Troubleshooting</span
                    >
                  </label>
                  <span class="service-price">₦10,000</span>
                </li>
                <li>
                  <label>
                    <input
                      type="checkbox"
                      class="service-check"
                      data-price="30000"
                      data-name="ICT Training (per package)"
                    />
                    <span class="service-name">ICT Training (per package)</span>
                  </label>
                  <span class="service-price">₦30,000</span>
                </li>
                <li>
                  <label>
                    <input
                      type="checkbox"
                      class="service-check"
                      data-price="15000"
                      data-name="Data Entry / Analysis"
                    />
                    <span class="service-name">Data Entry / Analysis</span>
                  </label>
                  <span class="service-price">₦15,000</span>
                </li>
              </ul>
            </div>

            <div class="quote-summary">
              <h3>Your quote</h3>
              <ul id="summaryList" class="summary-list">
                <li class="summary-empty">No services selected yet.</li>
              </ul>
              <div class="summary-total">
                <span>Total</span>
                <span id="totalAmount">₦0</span>
              </div>

              <label class="field">
                <span class="k">Full Name</span>
                <input
                  type="text"
                  id="payerName"
                  placeholder="Your full name"
                />
              </label>
              <label class="field">
                <span class="k">Email</span>
                <input
                  type="email"
                  id="payerEmail"
                  placeholder="you@example.com"
                />
              </label>

              <button
                type="button"
                id="payButton"
                class="btn btn-primary"
                disabled
              >
                Select a service to continue
              </button>
              <p
                class="form-status"
                id="paymentStatus"
                role="status"
                aria-live="polite"
              ></p>
              <p class="pay-note">
                Secure payment powered by Paystack. You'll be redirected back
                here once payment is complete.
              </p>
            </div>
          </div>
        </div>
      </section>
    </main>

    <footer>
      <img
        src="./IMAGES/logo.png"
        alt="Bibi Tech Compatibility logo"
        style="height: 36px; width: auto; margin: 0 auto 14px; opacity: 0.85"
      />
      <p>
        © <span id="year"></span> Idris Umar Ahmad · Bibi Tech Compatibility ·
        Kano State, Nigeria
      </p>
    </footer>

    <script src="https://js.paystack.co/v1/inline.js"></script>
    <script src="./script.js"></script>
  </body>
</html>
